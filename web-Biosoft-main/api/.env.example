# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT
JWT_SECRET=cambia_esto_por_una_clave_segura
JWT_EXPIRES_IN=24h

# ─── Brevo (ex Sendinblue) — Email transaccional ─────────────────────
# Usuario SMTP: el email de la cuenta Brevo
BREVO_SMTP_USER=tu_email@gmail.com
# Clave SMTP de Brevo — se obtiene en: Brevo > Configuración > SMTP & API > Claves SMTP
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxxxxxxxxxx
# Email que aparece como remitente
BREVO_SENDER_EMAIL=tu_email@gmail.com
# API Key REST de Brevo (opcional, para uso futuro)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx

# TTL de códigos de recuperación (minutos)
PASSWORD_RESET_TTL_MINUTES=15

# Servidor
PORT=3000
NODE_ENV=production

# CORS — URL del frontend (separar por comas si hay varios)
FRONTEND_URL=https://tu-frontend.onrender.com

# Cloudinary (para subida de imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
