# Database
DB_NAME=BioSoft
DB_USER=Colaborador
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://YOUR_NEON_USER:YOUR_NEON_PASSWORD@YOUR_NEON_HOST/YOUR_NEON_DB?sslmode=require&channel_binding=require&uselibpqcompat=true

# JWT
JWT_SECRET=mi_clave_ultra_secreta_cambiar_en_produccion
JWT_EXPIRES_IN=24h

# Email (SMTP) para enviar correos con Brevo
# Brevo SMTP oficial:
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USER=tu_smtp_login_brevo
# EMAIL_PASS=tu_smtp_key_brevo
# EMAIL_FROM=Bionatural <no-reply@tudominio.com>
# EMAIL_REPLY_TO=soporte@tudominio.com
#
# Notas:
# - Usa el SMTP login y SMTP key de Brevo, no la API key.
# - EMAIL_FROM debe ser un remitente o dominio verificado en Brevo.
# - Puerto 587 o 2525 para STARTTLS, 465 para SSL/TLS.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=YOUR_BREVO_SMTP_LOGIN
EMAIL_PASS=YOUR_BREVO_SMTP_KEY
EMAIL_FROM=Bionatural <no-reply@tudominio.com>
EMAIL_REPLY_TO=soporte@tudominio.com

# TTL de codigos (minutos)
EMAIL_CODE_TTL_MINUTES=15
PASSWORD_RESET_TTL_MINUTES=15

# Servidor
PORT=3000
